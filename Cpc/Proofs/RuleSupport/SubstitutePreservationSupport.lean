      (fun X Y hApp => by
        rw [hEoType X Y] at hApp
        exact eo_typeof_bvand_args_not_stuck_of_ne_stuck hApp)
      (fun X₁ Y₁ X₂ Y₂ hX hY => by
        rw [hEoType X₁ X₂, hEoType Y₁ Y₂]
