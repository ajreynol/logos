              (__eo_typeof Y₂)
        rw [hC, hX, hY])
      (fun C X Y hCTrans hXTrans hYTrans hApp => by
        unfold RuleProofs.eo_has_smt_translation
        change
          __smtx_typeof
              (SmtTerm.ite (__eo_to_smt C) (__eo_to_smt X)
                (__eo_to_smt Y)) ≠
            SmtType.None
        change
