          __eo_typeof y ∧
          RuleProofs.eo_has_smt_translation
            (__substitute_simul_rec (Term.Boolean false) y xs ts bvs)) :
    __eo_typeof
        (__substitute_simul_rec (Term.Boolean false)
          (Term.Apply (Term.Apply (Term.Apply (Term.UOp UserOp.ite) c) x) y)
          xs ts bvs) =
      __eo_typeof
        (Term.Apply (Term.Apply (Term.Apply (Term.UOp UserOp.ite) c) x) y) ∧
      RuleProofs.eo_has_smt_translation
        (__substitute_simul_rec (Term.Boolean false)
          (Term.Apply (Term.Apply (Term.Apply (Term.UOp UserOp.ite) c) x) y)
          xs ts bvs) := by
