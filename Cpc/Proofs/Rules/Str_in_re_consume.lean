            (__eo_list_singleton_elim (Term.UOp UserOp.str_concat)
              (__str_collect parts)))
          (__eo_list_singleton_elim (Term.UOp UserOp.re_concat)
            (__re_unflatten (Term.Boolean false) (Term.Boolean true)
              rePart)))
    (hSideNe : side ≠ Term.Stuck)
    (hPartsList :
