  | case8 rev hRevNe =>
      intro hRev hTy _hFlatNe
      subst rev
      simpa [__re_flatten] using hTy
  | case9 rev hRevNe =>
      intro hRev hTy _hFlatNe
      subst rev
      simpa [__re_flatten] using hTy
  | case10 rev body hRevNe ih =>
      intro hRev hTy hFlatNe
      subst rev
