private theorem re_unflatten_str_default_from_true_rel_local
    (M : SmtModel) (hM : model_total_typed M) (r : Term)
    (hTrue : re_unflatten_true_rel_local M r)
    (hNotStrPrefix :
      ∀ (s tail : Term),
