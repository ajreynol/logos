    (hCollectNe : __str_collect parts ≠ Term.Stuck)
    (hRePartTy :
      __smtx_typeof (__eo_to_smt rePart) = SmtType.RegLan)
    (hRePartEvalRel :
      ∀ rv,
        __smtx_model_eval M (__eo_to_smt r) = SmtValue.RegLan rv ->
          ∃ reRv,
            __smtx_model_eval M (__eo_to_smt rePart) =
