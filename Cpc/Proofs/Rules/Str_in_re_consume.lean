                        unfold term_has_non_none_type
                        rw [hLeftResidual.1]
                        simp)
                _ = SmtType.Seq SmtType.Char := hLeftResidual.1
            have hSeqValueTy :
                __smtx_typeof_value (SmtValue.Seq ss') =
                  SmtType.Seq SmtType.Char := by
              rw [← hTailEval]
              exact hTailEvalTy
            have hTailValid :
