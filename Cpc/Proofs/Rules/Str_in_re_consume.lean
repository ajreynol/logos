              (__eo_ite (Term.Boolean true) revC1 flatC1) =
            Term.Apply (Term.UOp UserOp.re_inter) revC1 := by
        rw [eo_ite_true]
        exact eo_mk_apply_eq_apply_of_ne_stuck
          (Term.UOp UserOp.re_inter) revC1
