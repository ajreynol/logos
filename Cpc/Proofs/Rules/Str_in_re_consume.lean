      eo_mk_apply_arg_ne_stuck_of_ne_stuck _ _ hInnerNe
    rcases eo_is_str_eq_true_cases s1 hStr with ⟨ys, rfl⟩
    cases head <;> simp [__eo_concat] at hConcatNe
    case String xs =>
