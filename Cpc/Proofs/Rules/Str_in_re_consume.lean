                __smtx_typeof_value
                    (__smtx_model_eval M
                      (__eo_to_smt (__str_membership_str side))) =
                  __smtx_typeof
                    (__eo_to_smt (__str_membership_str side)) :=
                    smt_model_eval_preserves_type_of_non_none M hM
