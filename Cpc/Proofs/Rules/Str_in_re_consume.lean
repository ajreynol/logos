        hAccTy hCollect
  have hHeadEval :
      __smtx_model_eval M (__eo_to_smt headRe) =
        SmtValue.RegLan
          (native_str_to_re (native_unpack_string collectedSs)) := by
    simpa [headRe, collectedString] using
      eval_str_to_re_reglan_consume_local M collectedString collectedSs
