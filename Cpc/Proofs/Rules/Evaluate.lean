private theorem eo_typeof_str_rev_eq_seq_arg
    {T U : Term} :
    __eo_typeof_str_rev T = Term.Apply (Term.UOp UserOp.Seq) U ->
    T = Term.Apply (Term.UOp UserOp.Seq) U := by
  intro h
  cases T <;> simp [__eo_typeof_str_rev] at h ⊢
  case Apply f x =>
    cases f <;> simp at h ⊢
    case UOp op =>
      cases op <;> simp at h ⊢
      assumption

