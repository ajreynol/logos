        (SmtTerm.Binary
          (native_zmult (native_nat_to_int (native_int_to_nat i)) w) m) =
      SmtValue.Binary
        (native_zmult (native_nat_to_int (native_int_to_nat i)) w) m
  rw [__smtx_model_eval.eq_5]

