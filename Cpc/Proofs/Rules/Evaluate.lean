        runCmp hEvalEqTy
    exact hEq.symm.trans hBvSleEoType
  have hAProgTy : __eo_typeof (__eo_prog_evaluate a) = Term.Bool :=
    eo_prog_evaluate_typeof_bool_of_smt_type_bitvec a w hATransA hATy
