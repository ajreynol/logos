    have hSSeqEq :
        strEval = native_pack_string str :=
      (RuleProofs.smt_seq_rel_iff_eq _ _).1 hSSeqRel
    have hNEval :
        __smtx_model_eval M (__eo_to_smt n) = SmtValue.Numeral start :=
