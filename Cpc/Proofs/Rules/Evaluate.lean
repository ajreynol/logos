    simpa [smt_bv_msb_set, p, r, Int.sub_eq_add_neg] using
      smt_bv_msb_true_eq_pow_add_mod_of_pos
        (w := w) (n := n) hwpos hw0 hCanon hSign
  have hPow : native_int_pow2 w = 2 * p := by
    simpa [p] using native_int_pow2_succ_pred (w := w) hwpos
