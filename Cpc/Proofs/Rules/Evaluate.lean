private theorem model_eval_bitvec_term_binary
    (M : SmtModel) (hM : model_total_typed M) (t : Term)
    (w : native_Nat)
    (hTy : __smtx_typeof (__eo_to_smt t) = SmtType.BitVec w) :
    ∃ n : native_Int,
      __smtx_model_eval M (__eo_to_smt t) =
