  let runCmp :=
    __eo_or
      (__eo_gt (eo_signed_bv_value (__run_evaluate b))
        (eo_signed_bv_value (__run_evaluate a)))
      (__eo_eq (eo_signed_bv_value (__run_evaluate a))
        (eo_signed_bv_value (__run_evaluate b)))
