      simpa [hRunB] using hBRel
    have hARelValue :
        RuleProofs.smt_value_rel
          (__smtx_model_eval M (__eo_to_smt a))
          (SmtValue.Boolean runA) := by
      simpa [__smtx_model_eval] using hARelBool
    have hBRelValue :
        RuleProofs.smt_value_rel
          (__smtx_model_eval M (__eo_to_smt b))
