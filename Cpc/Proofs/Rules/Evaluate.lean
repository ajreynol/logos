      simpa [runS] using hSRel
    have hNRelRun :
        RuleProofs.smt_value_rel
          (__smtx_model_eval M (__eo_to_smt n))
          (__smtx_model_eval M (__eo_to_smt runStart)) := by
      simpa [runStart] using hNRel
    have hMRelRun :
        RuleProofs.smt_value_rel
          (__smtx_model_eval M (__eo_to_smt m))
