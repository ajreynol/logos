                  exact run_evaluate_sound_apply_str_update_core M hM z y x rec
                    hATrans hEvalTy
              | _ =>
                  exact False.elim (hActive rfl)
          | _ =>
              exact False.elim (hActive rfl)
      | _ =>
          exact False.elim (hActive rfl)
