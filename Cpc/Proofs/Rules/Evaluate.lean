private theorem run_evaluate_rec_apply_apply_apply_arg3
    (M : SmtModel) (g z y x : Term)
    (rec :
      ∀ A : Term,
        sizeOf A <
            sizeOf (Term.Apply (Term.Apply (Term.Apply g z) y) x) ->
