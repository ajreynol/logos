    dsimp [eo_eval_sbv_to_int_rhs] at hTy
    rw [hRun, hRunGuard, eo_ite_false] at hTy
    simp [__eo_extract, __eo_eq, __eo_ite, native_ite, native_teq] at hTy
    change Term.Stuck = Term.UOp UserOp.Int at hTy
    cases hTy

