                (SmtValue.Seq (native_pack_string str))
                (SmtValue.Seq (native_pack_string []))
                (SmtValue.Seq (native_pack_string replStr))
          simp [__smtx_model_eval]]
        rw [show
            __smtx_model_eval M (__eo_to_smt (Term.String str)) =
