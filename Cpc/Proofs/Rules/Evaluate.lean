      (op := SmtTerm.bvashr) (t1 := __eo_to_smt a) (t2 := __eo_to_smt b)
      (by rw [__smtx_typeof.eq_def] <;> simp only) hBvAshrNN with
    ⟨w, hATy, hBTy⟩
